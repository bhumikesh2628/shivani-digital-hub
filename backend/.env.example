PORT=5000
# MongoDB Atlas Connection String (get free account at https://www.mongodb.com/cloud/atlas)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/csvshivani
JWT_SECRET=your_secret_key_here_change_this_in_production
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ADMIN_USER=admin
ADMIN_PASS=admin123

# Google Gemini API key for AI Chatbot (obtain from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
